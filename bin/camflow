#!/bin/bash
# camflow CLI wrapper.
#
# Resolves the repo root from this script's location, prepends src/
# to PYTHONPATH, and exec's the cli_entry.main module. Works whether
# this script is invoked directly, via $PATH, or through a symlink.
#
# Symlink-friendly path resolution: `readlink -f` follows symlinks so
# `/home/<user>/bin/camflow → <repo>/bin/camflow` still finds the repo.

set -euo pipefail

SCRIPT_PATH="$(readlink -f "$0")"
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd)"
SRC_DIR="$SCRIPT_DIR/src"

if [[ ! -d "$SRC_DIR/camflow" ]]; then
    echo "ERROR: camflow source not found at $SRC_DIR/camflow" >&2
    echo "       (resolved repo root: $SCRIPT_DIR)" >&2
    exit 2
fi

# Preserve any caller-set PYTHONPATH; prepend ours so the local
# checkout always wins over a system install.
if [[ -n "${PYTHONPATH:-}" ]]; then
    export PYTHONPATH="$SRC_DIR:$PYTHONPATH"
else
    export PYTHONPATH="$SRC_DIR"
fi

exec python3 -m camflow.cli_entry.main "$@"
